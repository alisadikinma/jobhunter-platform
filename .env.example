# Database
DATABASE_URL=postgresql://jobhunter:jobhunter@localhost:5433/jobhunter

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Claude CLI
CLAUDE_PATH=claude

# Apify (token encryption key — generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
APIFY_FERNET_KEY=
APIFY_LINKEDIN_ENABLED=false

# Adzuna API (register at https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Residential proxy (optional — for JobSpy LinkedIn bypass)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Firecrawl (self-hosted, internal Docker network)
FIRECRAWL_API_URL=http://firecrawl-api:3002

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
