# Environment (dev | prod). When not 'dev', JWT_SECRET and ADMIN_PASSWORD
# must be set to real values — defaults are rejected at startup.
ENV=dev

# Database
DATABASE_URL=postgresql://jobhunter:jobhunter@localhost:5433/jobhunter

# Auth — JWT_SECRET must be >=32 bytes in non-dev (RFC 7518 Sec 3.2).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Claude CLI
CLAUDE_PATH=claude

# Path to the jobhunter-plugin clone — separate repo at
# https://github.com/alisadikinma/jobhunter-plugin. Run `make plugin-init`
# to clone it as a sibling, then set this to the absolute path. In Docker
# the plugin is cloned into the image during build, so this is unset there.
CLAUDE_PLUGIN_PATH=

# Pandoc reference DOCX for tailored CVs. In Docker this is auto-generated
# at build time; on a dev host run `python backend/scripts/generate_cv_template.py`
# and point this at the resulting file. Empty = use Pandoc's built-in default.
CV_REFERENCE_DOCX=

# Apify (token encryption key — generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
APIFY_FERNET_KEY=
APIFY_LINKEDIN_ENABLED=false

# Custom-domain mailbox for cold-email drafts (recommended: alisadikinma.com).
# Drafts append via IMAP; user reviews + sends from any IMAP client.
# Auto-send is wired ONLY for follow-ups; initial cold outreach stays manual.
# Hostinger / Migadu / Fastmail all use the same coords pattern.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=465
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
MAIL_DRAFTS_FOLDER=INBOX.Drafts
# NOTE: Hostinger / most Dovecot-based providers expose the Drafts folder as
# "INBOX.Drafts". Bare "Drafts" returns NO [TRYCREATE] / nonexistent-namespace.
# Gmail uses "[Gmail]/Drafts". iCloud uses "Drafts". Verify with your client.

# Adzuna API (register at https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Residential proxy (optional — for JobSpy LinkedIn bypass)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Firecrawl (self-hosted, internal Docker network)
FIRECRAWL_API_URL=http://firecrawl-api:3002
FIRECRAWL_API_KEY=

# Claude CLI subprocess callbacks — shared secret, >=32 bytes in prod.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
CALLBACK_SECRET=
CALLBACK_API_URL=http://api:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Prod-only: postgres password for docker-compose.yml
POSTGRES_PASSWORD=

# Portfolio auditor scan roots (comma-separated)
PORTFOLIO_SCAN_PATHS=~/.claude/plugins/cache,D:/Projects
